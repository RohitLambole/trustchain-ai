NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/trustchain_ai
CORS_ORIGINS=http://localhost:3000

JWT_ACCESS_SECRET=replace-with-64-byte-access-secret
JWT_REFRESH_SECRET=replace-with-64-byte-refresh-secret
JWT_ISSUER=trustchain-ai
JWT_AUDIENCE=trustchain-ai-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

PASSWORD_BCRYPT_ROUNDS=12
TOTP_ISSUER=TrustChain AI
FIELD_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64-key

PASSWORD_RESET_TTL_SECONDS=900

BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
AUDIT_TRAIL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
BACKEND_WRITER_PRIVATE_KEY=replace-with-ganache-private-key
